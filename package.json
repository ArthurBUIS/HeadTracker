{
  "name": "head-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype: from one live video stream, emit N 200x200 streams each locked on and identity-tracking one participant's head.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.20.0",
    "@vladmandic/face-api": "^1.7.15"
  },
  "devDependencies": {
    "typescript": "^5.8.2",
    "vite": "^5.4.0"
  }
}
